# ── BSC Testnet Drill 配置 ──────────────────────────────────────────────
# 填入以下三项，然后运行: bash scripts/bsc_testnet_drill.sh
# 注意：这是测试网配置，不要用主网资金或主网私钥

# BSC Testnet 公共 RPC
BSC_TESTNET_RPC_URL=https://bsc-testnet-dataseed.bnbchain.org

# 测试钱包私钥（只用于测试网）
# 格式：0x开头的 64 位十六进制
BSC_TESTNET_PRIVATE_KEY=0x

# 测试钱包地址（和上面私钥对应的地址）
# 格式：0x开头的 40 位十六进制
BSC_TESTNET_OWNER=0x

# ── 以下不需要改 ─────────────────────────────────────────────────────────
LOCK_CONFIG=false
ARENA_ALLOW_INSECURE_PRIVATE_KEY=1
