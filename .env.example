# ── LLM Provider API Keys (set the one you use) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
DEEPSEEK_API_KEY=sk-...
# Ollama runs locally — no key needed

# ── Swap Executor ─────────────────────────────────────────────────
# Override yaml executor.provider: paper | moonpay | uniswap_v3 | zerox | coinbase
SWAP_EXECUTOR=
# Uniswap v3 (Base chain on-chain)
UNISWAP_PRIVATE_KEY=        # signer private key (0x...)
UNISWAP_RPC_URL=            # Base RPC (falls back to SYNAPTEX_CHAIN_RPC_URL)
# 0x Swap API v2
ZEROX_API_KEY=              # from 0x dashboard
ZEROX_RPC_URL=              # Base RPC (falls back to SYNAPTEX_CHAIN_RPC_URL)
ZEROX_PRIVATE_KEY=          # signer private key (0x...)
# Coinbase Advanced Trade (CEX, no RPC needed)
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ── BNB Chain ─────────────────────────────────────────────────────
BNB_RPC_URL=https://bsc-dataseed1.binance.org/
BNB_RPC_URL_BACKUP=https://bsc-dataseed2.binance.org/
WALLET_NAME=main

# ── Internal ──────────────────────────────────────────────────────
IPC_HOST=127.0.0.1
IPC_PORT=7890
API_PORT=3000
LOG_LEVEL=info
SYNAPTEX_API_HOST=0.0.0.0
SYNAPTEX_CORS_ORIGIN=*

# Arena settlement submitter (optional)
ARENA_SETTLEMENT_ENDPOINT=
ARENA_SETTLEMENT_AUTH_TOKEN=
ARENA_SETTLEMENT_HMAC_SECRET=
ARENA_SETTLEMENT_TIMEOUT_MS=5000
ARENA_SETTLEMENT_MAX_ATTEMPTS=3
ARENA_SETTLEMENT_BACKOFF_MS=750
ARENA_SETTLEMENT_DLQ_PATH=state/arena/settlement_submit_failures.jsonl
SYNAPTEX_SETTLEMENT_MODE=
SYNAPTEX_CHAIN_RPC_URL=
SYNAPTEX_SETTLER_CONTRACT=
ARENA_SETTLER_PRIVATE_KEY=
ARENA_CAST_BIN=
SYNAPTEX_SIGNER_KEYSTORE=
SYNAPTEX_SIGNER_PASSWORD=
SYNAPTEX_SIGNER_PRIVATE_KEY=
SYNAPTEX_ALLOW_INSECURE_PRIVATE_KEY=0
ARENA_CAST_USE_UNLOCKED=0
ARENA_CAST_FROM=
ARENA_SETTLEMENT_RECEIPTS_PATH=state/arena/settlement_receipts.jsonl
SYNAPTEX_WS_AUTH_TOKEN=
AGENT_NFA_CONTRACT=
AGENT_ACCOUNT_REGISTRY=
LEARNING_ROOT_ORACLE=
ARENA_LEARNING_RECEIPTS_PATH=state/arena/learning_root_receipts.jsonl
ARENA_ENABLE_AGENT_ONCHAIN_REGISTRATION=0
ARENA_AGENT_NFA_MINT_TO=
ARENA_AGENT_TOKEN_URI_PREFIX=ipfs://arena-agent
ARENA_AGENT_TBA_SALT=0
ARENA_AGENT_REGISTRATION_LOG_PATH=state/arena/agent_registration.jsonl
ARENA_SYNC_LEARNING_CURSOR_PATH=state/arena/sync_learning_cursor.json
ARENA_ALERT_WEBHOOK_URL=
ARENA_ALERT_WEBHOOK_URL_WARN=
ARENA_ALERT_WEBHOOK_URL_ERROR=
ARENA_ALERT_AUTH_TOKEN=
ARENA_ALERT_AUTH_TOKEN_WARN=
ARENA_ALERT_AUTH_TOKEN_ERROR=
ARENA_ALERT_TIMEOUT_MS=5000
ARENA_ALERT_MAX_ATTEMPTS=3
ARENA_ALERT_BACKOFF_MS=500
ARENA_ALERT_DEDUP_WINDOW_MS=60000
ARENA_ALERT_RATE_LIMIT_WINDOW_MS=60000
ARENA_ALERT_RATE_LIMIT_MAX=20
ARENA_ALERT_DLQ_PATH=state/arena/alert_failures.jsonl
ARENA_AGENT_SECRET_DEMO_WEBHOOK=local-dev-secret

# Phase 1 backend scaffold (SIWE + registry + postgres schema)
SYNAPTEX_DATABASE_URL=postgres://user:pass@127.0.0.1:5432/arena
SYNAPTEX_SIWE_NONCE_TTL_SECONDS=300
SYNAPTEX_SIWE_SESSION_TTL_SECONDS=86400
# 0 = scaffold mode (message-binding checks), 1 = strict mode (cast wallet verify)
SYNAPTEX_SIWE_ENFORCE_SIGNATURE_VERIFY=0
# Optional strict verifier command template (if set, overrides cast verifier):
# placeholders: {address} {signature} {message_b64}
# SYNAPTEX_SIWE_VERIFY_COMMAND=python scripts/verify_sig.py --address {address} --signature {signature} --message-b64 {message_b64}
SYNAPTEX_SIWE_VERIFY_COMMAND=
